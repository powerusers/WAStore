# -----------------------------------------------------------------------------
# Railway Variables (recommended for GitHub → Railway deploys)
# -----------------------------------------------------------------------------
# Set these in the Railway dashboard: your service → Variables.
# Do not commit secrets. This file is only a name/value reference.
#
# Railway often injects DATABASE_URL automatically when you add the Postgres
# plugin and link it to this service—verify it exists under Variables.
#
# NEXT_PUBLIC_* values are inlined at build time. After changing them in
# Railway, trigger a new deploy so `next build` picks them up.
# -----------------------------------------------------------------------------

# Required. Use your Railway Postgres connection string (pooled URL if offered).
# Example shape (values are fake):
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connection_limit=1
DATABASE_URL=

# Optional. Subdomain tenants: set to your apex domain (no protocol), e.g. myapp.com
# so purti.myapp.com resolves to tenant slug "purti". Omit on *.railway.app and use
# path URLs like /{tenantSlug} instead.
NEXT_PUBLIC_ROOT_DOMAIN=

# -----------------------------------------------------------------------------
# Local development (optional)
# -----------------------------------------------------------------------------
# Copy this file to .env (gitignored) if you run `npm run dev` on your machine.
